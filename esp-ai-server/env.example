# 小智AI服务 - 环境变量配置示例
# Xiaozhi AI Service - Environment Variables Example
# 复制此文件为 .env 并填写实际值

# ==================== 服务配置 ====================
# 服务名称和版本
SERVICE_NAME=小智AI服务
SERVICE_VERSION=2.0.0

# 支持的客户端类型（逗号分隔）
SUPPORTED_CLIENTS=esp32,web,mobile,desktop

# ==================== 基础配置 ====================
# 环境类型：development/production/test
ENVIRONMENT=development

# 调试模式
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8766
HTTP_PORT=8080

# 功能开关
ENABLE_OTA=true
ENABLE_WEBSOCKET=true
ENABLE_HTTP_API=false

# ==================== 安全配置 ====================
# 密钥（生产环境务必修改！）
SECRET_KEY=your-secret-key-change-in-production-please
PASSWORD_SALT=tomoe-chat-salt-change-me

# JWT配置（预留）
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRE_MINUTES=1440

# ==================== AI服务配置 ====================
# DashScope API密钥（必填）
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# LLM配置
LLM_MODEL=qwen3-max
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.8

# ASR配置
ASR_MODEL=paraformer-realtime-v2
ASR_SAMPLE_RATE=16000

# TTS配置
TTS_MODEL=cosyvoice-v2
TTS_VOICE=longhan_v2
TTS_SAMPLE_RATE=22050
TTS_VOLUME=50
TTS_SPEECH_RATE=1.0

# ==================== 业务配置 ====================
# 对话历史配置
MAX_HISTORY_MESSAGES=50
MAX_CONTEXT_MESSAGES=20

# WebSocket配置
HEARTBEAT_INTERVAL=30
HEARTBEAT_TIMEOUT=60
IDLE_TIMEOUT=300

# ==================== 日志配置 ====================
# 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==================== 数据库配置（预留） ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/tomoe_chat
# REDIS_URL=redis://localhost:6379/0

# ==================== CORS配置 ====================
# 允许的跨域来源，多个用逗号分隔
CORS_ORIGINS=*

# ==================== 监控配置（预留） ====================
ENABLE_METRICS=False
METRICS_PORT=9090

